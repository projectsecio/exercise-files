---
import AppShell from '../layouts/AppShell.astro';
import { getDashboardPanels } from '../lib/db';
import DomainsBarChart from '../components/charts/DomainsBarChart';
import CountriesMapChart from '../components/charts/CountriesMapChart';
import { inputClass, cardClass } from '../lib/ui';
import LabFlag from '../components/LabFlag.astro';
import { LAB_FLAGS, detectSsrfResponse, detectXssPayload } from '../lib/lab/flags';
import { unsafeFetchUrl } from '../lib/lab/ssrf';
import { addComment, listComments } from '../lib/lab/xss';

const username = Astro.locals.username ?? 'guest';
const feedUrl = Astro.url.searchParams.get('feed_url') ?? '';
let feedResult: Awaited<ReturnType<typeof unsafeFetchUrl>> | null = null;
let feedError: string | null = null;
let discussionFlash: string | null = null;
let labFlag: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  if (String(form.get('form') ?? '') === 'discussion') {
    const body = String(form.get('body') ?? '').trim();
    if (body) {
      await addComment(username, body);
      discussionFlash = 'Posted to team thread.';
      if (detectXssPayload(body)) labFlag = LAB_FLAGS.xss;
    }
  }
}

if (feedUrl) {
  try {
    feedResult = await unsafeFetchUrl(feedUrl);
    if (feedResult && detectSsrfResponse(feedResult.body)) labFlag = LAB_FLAGS.ssrf;
  } catch (e) {
    feedError = e instanceof Error ? e.message : 'Could not retrieve feed';
  }
}

const comments = await listComments();
if (!labFlag && comments.some((c) => detectXssPayload(c.body))) {
  labFlag = LAB_FLAGS.xss;
}
const panels = await getDashboardPanels();

const PANEL_DISPLAY_ORDER = [
	'top_10_countries_by_ip',
	'security_news_rss',
	'top_100_domains',
	'top_malware_hashes',
	'top_ips',
	'top_iocs',
] as const;

const panelOrderRank = Object.fromEntries(
	PANEL_DISPLAY_ORDER.map((name, i) => [name, i])
);
const orderedPanels = [...panels].sort(
	(a, b) => (panelOrderRank[a.panelName] ?? 999) - (panelOrderRank[b.panelName] ?? 999)
);

function panelGridClass(panelName: string): string {
	const map: Record<string, string> = {
		top_10_countries_by_ip: 'col-span-1 sm:col-span-2 xl:col-span-6',
		security_news_rss: 'col-span-1 sm:col-span-1 xl:col-span-2',
		top_100_domains: 'col-span-1 sm:col-span-1 xl:col-span-2',
		top_malware_hashes: 'col-span-1 sm:col-span-2 xl:col-span-2',
		top_ips: 'col-span-1 sm:col-span-1 xl:col-span-3',
		top_iocs: 'col-span-1 sm:col-span-1 xl:col-span-3',
	};
	return map[panelName] ?? 'col-span-1 sm:col-span-1 xl:col-span-2';
}

const panelTitles: Record<string, string> = {
	security_news_rss: 'Security News RSS',
	top_100_domains: 'Top Domains',
	top_ips: 'Top IPs',
	top_10_countries_by_ip: 'Top 10 Countries by IP',
	top_malware_hashes: 'Top Malware Hashes',
	top_iocs: 'Top IOCs',
};

function formatCollected(iso: string | null) {
	if (!iso) return '—';
	try {
		return new Date(iso).toLocaleString(undefined, {
			dateStyle: 'medium',
			timeStyle: 'short',
		});
	} catch {
		return iso;
	}
}
---

<AppShell title="Dashboard · Threat Intel" heading="Dashboard">
	{labFlag && <LabFlag message={labFlag} />}
	<section class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-6 xl:gap-6">
		{
			orderedPanels.map((panel) => (
				<article
					class:list={[
						'group rounded-2xl border border-white/[0.06] bg-white/[0.02] p-5 shadow-[0_1px_0_0_rgb(255_255_255_/_0.04)_inset] backdrop-blur-sm transition-colors hover:border-white/[0.09] sm:p-6',
						panelGridClass(panel.panelName),
					]}
				>
					<div class="mb-4 flex items-start justify-between gap-3">
						<h2 class="text-[15px] font-medium leading-snug tracking-tight text-zinc-100">
							{panelTitles[panel.panelName] ?? panel.panelName}
						</h2>
						<span class="shrink-0 rounded-full border border-white/[0.06] bg-white/[0.03] px-2.5 py-0.5 text-[11px] tabular-nums text-zinc-400">
							{panel.items.length}
						</span>
					</div>

					<p class="mb-4 text-[11px] text-zinc-500">
						Updated {formatCollected(panel.collectedAt)} · {panel.sourceFeed}
					</p>

					{panel.items.length === 0 ? (
						<p class="text-sm text-zinc-500">No items yet for this panel.</p>
					) : panel.panelName === 'security_news_rss' ? (
						<div class:list={[panel.items.length > 10 && 'feed-scroll']}>
							<ul class="space-y-2.5">
								{panel.items.map((item) => (
									<li class="rounded-xl border border-white/[0.06] bg-black/20 p-3.5 text-sm">
										<span class="font-medium text-sky-400/90">{item.title || 'Untitled'}</span>
										{item.published && (
											<p class="mt-1.5 text-xs text-zinc-500">{item.published}</p>
										)}
									</li>
								))}
							</ul>
						</div>
					) : panel.panelName === 'top_100_domains' ? (
						<DomainsBarChart client:only="react" items={panel.items} />
					) : panel.panelName === 'top_10_countries_by_ip' ? (
						<CountriesMapChart client:only="react" items={panel.items} />
					) : panel.panelName === 'top_ips' ? (
						<div class:list={[panel.items.length > 10 && 'feed-scroll']}>
							<ul class="divide-y divide-white/[0.05] overflow-hidden rounded-xl border border-white/[0.06] bg-black/20">
								{panel.items.map((item) => (
									<li class="flex items-center justify-between gap-2 px-3.5 py-2.5 text-sm">
										<span class="truncate font-mono text-sky-400/90">
											{item.title || item.ip || '—'}
										</span>
										{item.count != null && (
											<span class="shrink-0 rounded-md border border-sky-500/20 bg-sky-500/10 px-2 py-0.5 text-xs tabular-nums text-sky-200/90">
												{item.count}
											</span>
										)}
									</li>
								))}
							</ul>
						</div>
					) : panel.panelName === 'top_malware_hashes' ? (
						<div class:list={[panel.items.length > 10 && 'feed-scroll']}>
							<ul class="divide-y divide-white/[0.05] overflow-hidden rounded-xl border border-white/[0.06] bg-black/20">
								{panel.items.map((item) => (
									<li class="flex items-start justify-between gap-2 px-3.5 py-2.5 text-sm">
										<div class="min-w-0 flex-1">
											<span class="break-all font-mono text-xs text-sky-400/90">
												{item.hash || item.title}
											</span>
											{item.malware && (
												<p class="mt-1 text-xs text-zinc-500">{item.malware}</p>
											)}
										</div>
										{item.count != null && (
											<span class="shrink-0 rounded-md border border-sky-500/20 bg-sky-500/10 px-2 py-0.5 text-xs tabular-nums text-sky-200/90">
												{item.count}
											</span>
										)}
									</li>
								))}
							</ul>
						</div>
					) : (
						<div class:list={[panel.items.length > 10 && 'feed-scroll']}>
							<ul class="divide-y divide-white/[0.05] overflow-hidden rounded-xl border border-white/[0.06] bg-black/20">
								{panel.items.map((item) => (
									<li class="px-3.5 py-2.5 text-sm text-zinc-200">
										{item.title || item.ioc_value || '—'}
										{item.ioc_type && (
											<span class="ml-2 rounded-md border border-white/[0.06] bg-white/[0.04] px-1.5 py-0.5 text-[10px] uppercase tracking-wide text-zinc-400">
												{item.ioc_type}
											</span>
										)}
									</li>
								))}
							</ul>
						</div>
					)}
				</article>
			))
		}
	</section>

	<section class="mt-8 grid grid-cols-1 gap-5 lg:grid-cols-2">
		<article class={cardClass}>
			<h2 class="text-[15px] font-medium text-zinc-100">Remote feed validation</h2>
			<p class="mt-1 text-xs text-zinc-500">
				Pull a sample response from a candidate RSS or JSON feed URL before adding it to ingestion.
			</p>
			<form class="mt-4 flex flex-col gap-2 sm:flex-row" method="get">
				<input
					class:list={[inputClass, 'font-mono text-xs sm:text-sm']}
					name="feed_url"
					type="url"
					value={feedUrl}
					placeholder="https://feeds.example.com/threat.xml"
				/>
				<button
					type="submit"
					class="shrink-0 rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-500"
				>
					Validate
				</button>
			</form>
			{feedError && <p class="mt-3 text-sm text-rose-300">{feedError}</p>}
			{
				feedResult && (
					<div class="mt-4">
						<p class="text-xs text-zinc-500">
							HTTP {feedResult.status} · {feedResult.contentType}
						</p>
						<pre class="mt-2 max-h-48 overflow-auto rounded-lg border border-white/[0.08] bg-black/40 p-3 text-xs text-zinc-400">
							{feedResult.body}
						</pre>
					</div>
				)
			}
		</article>

		<article class={cardClass}>
			<h2 class="text-[15px] font-medium text-zinc-100">Analyst collaboration</h2>
			<p class="mt-1 text-xs text-zinc-500">Share IOC context with the shift team.</p>
			{discussionFlash && <p class="mt-3 text-sm text-emerald-300">{discussionFlash}</p>}
			<form class="mt-4 space-y-3" method="post">
				<input type="hidden" name="form" value="discussion" />
				<textarea
					class={inputClass}
					name="body"
					rows="2"
					placeholder="Note a domain, hash, or TTP…"
					required
				/>
				<button
					type="submit"
					class="rounded-lg border border-white/[0.08] bg-white/[0.04] px-4 py-2 text-sm text-zinc-200 hover:bg-white/[0.08]"
				>
					Post
				</button>
			</form>
			<ul class="mt-6 max-h-64 space-y-3 overflow-y-auto">
				{
					comments.slice(0, 8).map((c) => (
						<li class="rounded-lg border border-white/[0.06] bg-black/20 px-3 py-2.5">
							<p class="text-[10px] text-zinc-500">
								{c.author} · {c.created_at}
							</p>
							<div class="mt-1 text-sm text-zinc-200" set:html={c.body} />
						</li>
					))
				}
			</ul>
		</article>
	</section>
</AppShell>
