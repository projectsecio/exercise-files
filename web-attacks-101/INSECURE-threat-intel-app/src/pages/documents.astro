---
import AppShell from '../layouts/AppShell.astro';
import { inputClass, cardClass } from '../lib/ui';
import LabFlag from '../components/LabFlag.astro';
import { LAB_FLAGS, detectIdor } from '../lib/lab/flags';
import { getDocumentById, listUserDocuments, createDocument } from '../lib/lab/idor';

const username = Astro.locals.username ?? 'analyst';

let composeFlash: string | null = null;
let newDocId: number | null = null;
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  if (String(form.get('form') ?? '') === 'new-note') {
    const title = String(form.get('title') ?? '').trim();
    const body = String(form.get('body') ?? '').trim();
    if (title && body) {
      const created = await createDocument(username, title, body);
      newDocId = created.id;
      composeFlash = `Saved note · Ref ${created.id}.`;
    }
  }
}

const idParam = Astro.url.searchParams.get('id') ?? '';
const docId = Number.parseInt(idParam, 10);
const doc = idParam.trim() && Number.isFinite(docId) ? await getDocumentById(docId) : null;
const labFlag = detectIdor(doc, username) ? LAB_FLAGS.idor : null;
const recentDocs = await listUserDocuments(username);
---

<AppShell title="Documents · Threat Intel" heading="Internal documents">
  {labFlag && <LabFlag message={labFlag} />}
  <p class="mb-6 max-w-2xl text-sm text-zinc-400">
    Analyst memos and operational records. Open by reference number or from your recent list.
  </p>

  <div class="grid gap-6 lg:grid-cols-[240px_1fr]">
    <aside class={cardClass}>
      <h2 class="text-sm font-medium text-zinc-200">Recent</h2>
      <ul class="mt-3 space-y-2 text-sm">
        {
          recentDocs.map((note) => (
            <li>
              <a
                class:list={[
                  'text-sky-400 hover:underline',
                  (docId === note.id || newDocId === note.id) && 'font-medium',
                ]}
                href={`/documents?id=${note.id}`}
              >
                {note.title}
              </a>
              <span class="block text-xs text-zinc-500">Ref {note.id} · You</span>
            </li>
          ))
        }
      </ul>

      <div class="mt-5 border-t border-white/[0.06] pt-4">
        <h3 class="text-sm font-medium text-zinc-200">New note</h3>
        {composeFlash && <p class="mt-2 text-xs text-emerald-300">{composeFlash}</p>}
        <form class="mt-3 space-y-2" method="post">
          <input type="hidden" name="form" value="new-note" />
          <label class="sr-only" for="note-title">Title</label>
          <input
            class={inputClass}
            id="note-title"
            name="title"
            type="text"
            placeholder="Title"
            required
          />
          <label class="sr-only" for="note-body">Note</label>
          <textarea
            class={inputClass}
            id="note-body"
            name="body"
            rows="3"
            placeholder="Write your note…"
            required
          />
          <button
            type="submit"
            class="w-full rounded-lg border border-white/[0.08] bg-white/[0.04] px-4 py-2 text-sm text-zinc-200 hover:bg-white/[0.08]"
          >
            Post note
          </button>
        </form>
      </div>
    </aside>

    <section class={cardClass}>
      <form class="mb-6 flex max-w-md gap-2" method="get">
        <label class="sr-only" for="ref">Reference number</label>
        <input
          class={inputClass}
          id="ref"
          name="id"
          type="text"
          inputmode="numeric"
          value={idParam}
          placeholder="Reference #"
        />
        <button
          type="submit"
          class="shrink-0 rounded-lg bg-sky-600 px-4 py-2 text-sm text-white hover:bg-sky-500"
        >
          Open
        </button>
      </form>

      {
        doc ? (
          <article>
            {doc.confidential && (
              <span class="mb-2 inline-block rounded-full border border-amber-500/40 bg-amber-500/10 px-2 py-0.5 text-[10px] uppercase tracking-wide text-amber-300">
                Sensitive
              </span>
            )}
            <h3 class="text-lg font-medium text-zinc-100">{doc.title}</h3>
            <p class="mt-1 text-xs text-zinc-500">
              Ref {doc.id} · {doc.owner_username}
            </p>
            <p class="mt-4 whitespace-pre-wrap text-sm leading-relaxed text-zinc-300">{doc.body}</p>
          </article>
        ) : (
          <p class="text-sm text-zinc-500">No document found for that reference.</p>
        )
      }
    </section>
  </div>
</AppShell>
