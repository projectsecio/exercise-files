---
import '../styles/global.css';

const error = Astro.url.searchParams.get('error');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sign in · INSECURE Threat Intel</title>
  </head>
  <body
    class="flex min-h-screen items-center justify-center bg-zinc-950 px-4 text-zinc-100 antialiased"
  >
    <div
      class="w-full max-w-md rounded-2xl border border-white/[0.08] bg-white/[0.02] p-8 shadow-xl"
    >
      <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-zinc-500">
        Local lab only
      </p>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight">INSECURE Threat Intel</h1>
      <p class="mt-2 text-sm text-zinc-400">
        Synthetic feeds and attack notes. Default Docker credentials are in <code
          class="text-zinc-300">docker/.env.example</code
        >.
      </p>

      {
        error && (
          <p class="mt-4 rounded-lg border border-rose-500/30 bg-rose-950/40 px-3 py-2 text-sm text-rose-200">
            Invalid username or password.
          </p>
        )
      }

      <form class="mt-6 space-y-4" method="post" action="/api/auth/login">
        <div>
          <label class="mb-1 block text-xs font-medium text-zinc-400" for="username"
            >Username</label
          >
          <input
            class="w-full rounded-lg border border-white/[0.08] bg-black/30 px-3 py-2 text-sm outline-none ring-sky-500/40 focus:ring-2"
            id="username"
            name="username"
            type="text"
            autocomplete="username"
            required
          />
        </div>
        <div>
          <label class="mb-1 block text-xs font-medium text-zinc-400" for="password"
            >Password</label
          >
          <input
            class="w-full rounded-lg border border-white/[0.08] bg-black/30 px-3 py-2 text-sm outline-none ring-sky-500/40 focus:ring-2"
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
          />
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-sky-600 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-sky-500"
        >
          Sign in
        </button>
      </form>
    </div>
  </body>
</html>
