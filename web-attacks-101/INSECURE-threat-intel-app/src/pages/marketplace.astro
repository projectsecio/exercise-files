---
import AppShell from '../layouts/AppShell.astro';
import { inputClass, cardClass } from '../lib/ui';
import LabFlag from '../components/LabFlag.astro';
import {
  LAB_FLAGS,
  detectSqliLogin,
  detectSqliSearch,
} from '../lib/lab/flags';
import { unsafeLabLogin, unsafeProductSearch } from '../lib/lab/sqli';

const q = Astro.url.searchParams.get('q') ?? '';
const loginError = Astro.url.searchParams.get('login') === 'fail';
let partnerUser: string | null = null;
let products: Awaited<ReturnType<typeof unsafeProductSearch>> = [];
let searchError: string | null = null;
let labFlag: string | null = null;
let partnerUsername = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  if (String(form.get('action') ?? '') === 'partner') {
    partnerUsername = String(form.get('username') ?? '');
    const password = String(form.get('password') ?? '');
    const user = await unsafeLabLogin(partnerUsername, password);
    if (user) {
      partnerUser = user.username;
      if (detectSqliLogin(partnerUsername, true)) labFlag = LAB_FLAGS.sqli;
    } else return Astro.redirect('/marketplace?login=fail');
  }
}

if (q) {
  try {
    products = await unsafeProductSearch(q);
    if (detectSqliSearch(q, products.length)) labFlag = LAB_FLAGS.sqli;
  } catch (e) {
    searchError = e instanceof Error ? e.message : 'Search unavailable';
  }
}
---

<AppShell title="Marketplace · Threat Intel" heading="Threat intel marketplace">
  {labFlag && <LabFlag message={labFlag} />}
  <p class="mb-6 max-w-2xl text-sm text-zinc-400">
    Browse add-ons and integrations for your ProjectX threat intelligence deployment.
  </p>

  <section class:list={[cardClass, 'mb-8']}>
    <h2 class="text-[15px] font-medium text-zinc-100">Catalog search</h2>
    <p class="mt-1 text-xs text-zinc-500">Licenses, feed modules, and enrichment packs.</p>
    <form class="mt-4 flex gap-2" method="get">
      <input class={inputClass} name="q" type="search" value={q} placeholder="Search by name or keyword…" />
      <button
        type="submit"
        class="shrink-0 rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-500"
      >
        Search
      </button>
    </form>
    {searchError && (
      <p class="mt-4 text-sm text-rose-300">{searchError}</p>
    )}
    {q && !searchError && products.length === 0 && (
      <p class="mt-4 text-sm text-zinc-500">No matching products.</p>
    )}
    {products.length > 0 && (
      <ul class="mt-4 divide-y divide-white/[0.06] rounded-xl border border-white/[0.06]">
        {
          products.map((p) => (
            <li class="px-4 py-3 text-sm">
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <span class="font-medium text-zinc-100">{p.name}</span>
                <span class="text-zinc-400">${p.price}</span>
              </div>
              <p class="mt-1 text-zinc-500">{p.description}</p>
            </li>
          ))
        }
      </ul>
    )}
  </section>

  <section class={cardClass}>
    <h2 class="text-[15px] font-medium text-zinc-100">Partner portal</h2>
    <p class="mt-1 text-xs text-zinc-500">
      Vendors with an existing distribution agreement can manage listings here.
    </p>
    {partnerUser && (
      <p class="mt-3 text-sm text-emerald-300">
        Signed in to partner portal as <strong>{partnerUser}</strong>.
      </p>
    )}
    {loginError && (
      <p class="mt-3 text-sm text-rose-300">Invalid partner credentials.</p>
    )}
    <form class="mt-4 max-w-sm space-y-3" method="post">
      <input type="hidden" name="action" value="partner" />
      <input class={inputClass} name="username" placeholder="Partner ID" autocomplete="username" />
      <input
        class={inputClass}
        name="password"
        type="password"
        placeholder="Password"
        autocomplete="current-password"
      />
      <button
        type="submit"
        class="rounded-lg border border-white/[0.08] bg-white/[0.04] px-4 py-2 text-sm text-zinc-200 hover:bg-white/[0.08]"
      >
        Sign in
      </button>
    </form>
  </section>
</AppShell>
