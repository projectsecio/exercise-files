---
import AppShell from '../../layouts/AppShell.astro';
import VulnBanner from '../../components/lab/VulnBanner.astro';
import { unsafePing } from '../../lib/lab/cmd';

const host = Astro.url.searchParams.get('host') ?? '';
let output: string | null = null;
let cmdError: string | null = null;

if (host) {
  try {
    output = await unsafePing(host);
  } catch (e) {
    cmdError = e instanceof Error ? e.message : 'Command failed';
  }
}

const inputClass =
  'w-full rounded-lg border border-white/[0.08] bg-black/30 px-3 py-2 font-mono text-sm outline-none ring-sky-500/40 focus:ring-2';
---

<AppShell title="Command injection lab" heading="Command injection lab">
  <VulnBanner
    attack="Command injection"
    hint="Host parameter is passed to ping without sanitization. Try 127.0.0.1; id or 127.0.0.1 && whoami"
  />

  <section class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6">
    <h2 class="text-sm font-medium text-zinc-200">Network reachability check</h2>
    <form class="mt-4 flex gap-2" method="get">
      <input class={inputClass} name="host" type="text" value={host} placeholder="8.8.8.8" />
      <button
        type="submit"
        class="shrink-0 rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-500"
      >
        Ping
      </button>
    </form>

    {cmdError && (
      <pre class="mt-4 overflow-x-auto rounded-lg border border-rose-500/30 bg-rose-950/30 p-3 text-xs text-rose-200">
        {cmdError}
      </pre>
    )}
    {output && (
      <pre class="mt-4 overflow-x-auto rounded-lg border border-white/[0.08] bg-black/40 p-4 text-xs text-zinc-300">
        {output}
      </pre>
    )}
  </section>

  <p class="mt-6 text-sm">
    <a class="text-sky-400 hover:underline" href="/lab">← All lab scenarios</a>
  </p>
</AppShell>
