---
import AppShell from '../layouts/AppShell.astro';
import { ATTACK_SCENARIOS } from '../lib/attacks';
import AttacksGrid from '../components/attacks/AttacksGrid';
---

<AppShell title="Field notes · Threat Intel" heading="Field notes">
  <p class="mb-8 max-w-2xl text-sm text-zinc-400">
    Document findings from your assessment. Course walkthroughs and methodology live in the hosted
    WA101 docs — use <strong class="font-medium text-zinc-300">Open notes</strong> below to record
    what you discover in the application.
  </p>
  <AttacksGrid client:load attacks={ATTACK_SCENARIOS} />
</AppShell>
