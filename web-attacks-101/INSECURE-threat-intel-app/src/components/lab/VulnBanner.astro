---
interface Props {
  attack: string;
  hint?: string;
}

const { attack, hint } = Astro.props;
---

<div class="mb-6 rounded-xl border border-amber-500/40 bg-amber-950/30 px-4 py-3 text-sm text-amber-100">
  <p class="font-medium">Intentionally vulnerable — {attack}</p>
  {hint && <p class="mt-1 text-amber-200/80">{hint}</p>}
  <p class="mt-2 text-xs text-amber-200/60">
    Local lab only. Use Burp and document in <a class="underline" href="/attacks">Attacks → Open notes</a>.
  </p>
</div>
