---
import "../styles/global.css";
import { getLatestSecurityNews } from "../lib/db";

const items = await getLatestSecurityNews(5);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Security News RSS Panel</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100">
    <main class="mx-auto max-w-3xl p-6">
      <h1 class="text-2xl font-bold">Security News RSS Panel</h1>
      <p class="mt-2 text-sm text-slate-400">Latest 5 from BleepingComputer</p>

      <ul class="mt-6 space-y-3">
        {
          items.length === 0 ? (
            <li class="rounded border border-slate-800 bg-slate-900 p-4 text-slate-300">
              No RSS items found yet.
            </li>
          ) : (
            items.map((item) => (
              <li class="rounded border border-slate-800 bg-slate-900 p-4">
                <a
                  class="text-blue-300 hover:text-blue-200 hover:underline"
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {item.title || "Untitled article"}
                </a>
                {item.published && (
                  <p class="mt-1 text-xs text-slate-400">{item.published}</p>
                )}
              </li>
            ))
          )
        }
      </ul>
    </main>
  </body>
</html>
