---
import '../styles/global.css';
import { getDashboardPanels } from '../lib/db';
import DomainsBarChart from '../components/charts/DomainsBarChart';
import CountriesMapChart from '../components/charts/CountriesMapChart';

const panels = await getDashboardPanels();

/** Visual order and grid placement (xl uses 6 columns). */
const PANEL_DISPLAY_ORDER = [
	'top_10_countries_by_ip',
	'security_news_rss',
	'top_100_domains',
	'top_malware_hashes',
	'top_ips',
	'top_iocs',
] as const;

const panelOrderRank = Object.fromEntries(
	PANEL_DISPLAY_ORDER.map((name, i) => [name, i])
);
const orderedPanels = [...panels].sort(
	(a, b) => (panelOrderRank[a.panelName] ?? 999) - (panelOrderRank[b.panelName] ?? 999)
);

function panelGridClass(panelName: string): string {
	const map: Record<string, string> = {
		top_10_countries_by_ip: 'col-span-1 sm:col-span-2 xl:col-span-6',
		security_news_rss: 'col-span-1 sm:col-span-1 xl:col-span-2',
		top_100_domains: 'col-span-1 sm:col-span-1 xl:col-span-2',
		top_malware_hashes: 'col-span-1 sm:col-span-2 xl:col-span-2',
		top_ips: 'col-span-1 sm:col-span-1 xl:col-span-3',
		top_iocs: 'col-span-1 sm:col-span-1 xl:col-span-3',
	};
	return map[panelName] ?? 'col-span-1 sm:col-span-1 xl:col-span-2';
}

const panelTitles: Record<string, string> = {
	security_news_rss: 'Security News RSS',
	top_100_domains: 'Top Domains',
	top_ips: 'Top IPs',
	top_10_countries_by_ip: 'Top 10 Countries by IP',
	top_malware_hashes: 'Top Malware Hashes',
	top_iocs: 'Top IOCs',
};

function formatCollected(iso: string | null) {
	if (!iso) return '—';
	try {
		return new Date(iso).toLocaleString(undefined, {
			dateStyle: 'medium',
			timeStyle: 'short',
		});
	} catch {
		return iso;
	}
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Threat intelligence · Dashboard</title>
	</head>
	<body class="min-h-screen bg-zinc-950 bg-[radial-gradient(ellipse_120%_80%_at_50%_-20%,rgb(39_39_42_/_0.35),transparent)] text-zinc-100 antialiased">
		<main class="mx-auto max-w-7xl px-5 py-10 sm:px-8">
			<header class="mb-10 border-b border-white/[0.06] pb-8">
				<p class="text-[11px] font-medium uppercase tracking-[0.2em] text-zinc-500">Threat intelligence</p>
				<h1 class="mt-1 text-2xl font-semibold tracking-tight text-white sm:text-3xl">Dashboard</h1>
			</header>

			<section class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-6 xl:gap-6">
				{
					orderedPanels.map((panel) => (
						<article
							class:list={[
								'group rounded-2xl border border-white/[0.06] bg-white/[0.02] p-5 shadow-[0_1px_0_0_rgb(255_255_255_/_0.04)_inset] backdrop-blur-sm transition-colors hover:border-white/[0.09] sm:p-6',
								panelGridClass(panel.panelName),
							]}
						>
							<div class="mb-4 flex items-start justify-between gap-3">
								<h2 class="text-[15px] font-medium leading-snug tracking-tight text-zinc-100">
									{panelTitles[panel.panelName] ?? panel.panelName}
								</h2>
								<span class="shrink-0 rounded-full border border-white/[0.06] bg-white/[0.03] px-2.5 py-0.5 text-[11px] tabular-nums text-zinc-400">
									{panel.items.length}
								</span>
							</div>

							<p class="mb-4 text-[11px] text-zinc-500">
								Updated {formatCollected(panel.collectedAt)}
							</p>

							{panel.items.length === 0 ? (
								<p class="text-sm text-zinc-500">No items yet for this panel.</p>
							) : panel.panelName === 'security_news_rss' ? (
								<div class:list={[panel.items.length > 10 && 'feed-scroll']}>
									<ul class="space-y-2.5">
										{panel.items.map((item) => (
											<li class="rounded-xl border border-white/[0.06] bg-black/20 p-3.5 text-sm">
												<a
													class="font-medium text-sky-400/90 transition-colors hover:text-sky-300 hover:underline"
													href={item.url}
													target="_blank"
													rel="noopener noreferrer"
												>
													{item.title || 'Untitled article'}
												</a>
												{item.published && (
													<p class="mt-1.5 text-xs text-zinc-500">{item.published}</p>
												)}
											</li>
										))}
									</ul>
								</div>
							) : panel.panelName === 'top_100_domains' ? (
								<DomainsBarChart client:only="react" items={panel.items} />
							) : panel.panelName === 'top_10_countries_by_ip' ? (
								<CountriesMapChart client:only="react" items={panel.items} />
							) : panel.panelName === 'top_ips' ? (
								<div class:list={[panel.items.length > 10 && 'feed-scroll']}>
									<ul class="divide-y divide-white/[0.05] overflow-hidden rounded-xl border border-white/[0.06] bg-black/20">
										{panel.items.map((item) => (
											<li class="flex items-center justify-between gap-2 px-3.5 py-2.5 text-sm">
												<a
													class="truncate text-sky-400/90 transition-colors hover:text-sky-300 hover:underline"
													href={item.url}
													target="_blank"
													rel="noopener noreferrer"
												>
													{item.title || item.url || '—'}
												</a>
												{item.count != null && (
													<span class="shrink-0 rounded-md border border-sky-500/20 bg-sky-500/10 px-2 py-0.5 text-xs tabular-nums text-sky-200/90">
														{item.count}
													</span>
												)}
											</li>
										))}
									</ul>
								</div>
							) : panel.panelName === 'top_malware_hashes' ? (
								<div class:list={[panel.items.length > 10 && 'feed-scroll']}>
									<ul class="divide-y divide-white/[0.05] overflow-hidden rounded-xl border border-white/[0.06] bg-black/20">
										{panel.items.map((item) => (
											<li class="flex items-start justify-between gap-2 px-3.5 py-2.5 text-sm">
												<div class="min-w-0 flex-1">
													<a
														class="break-all font-mono text-xs text-sky-400/90 transition-colors hover:text-sky-300 hover:underline"
														href={item.url}
														target="_blank"
														rel="noopener noreferrer"
													>
														{item.hash || item.title || item.url}
													</a>
													{item.malware && (
														<p class="mt-1 text-xs text-zinc-500">{item.malware}</p>
													)}
												</div>
												{item.count != null && (
													<span class="shrink-0 rounded-md border border-sky-500/20 bg-sky-500/10 px-2 py-0.5 text-xs tabular-nums text-sky-200/90">
														{item.count}
													</span>
												)}
											</li>
										))}
									</ul>
								</div>
							) : (
								<div class:list={[panel.items.length > 10 && 'feed-scroll']}>
									<ul class="divide-y divide-white/[0.05] overflow-hidden rounded-xl border border-white/[0.06] bg-black/20">
										{panel.items.map((item) => (
											<li class="px-3.5 py-2.5 text-sm">
												{item.url ? (
													<a
														class="text-sky-400/90 transition-colors hover:text-sky-300 hover:underline"
														href={item.url}
														target="_blank"
														rel="noopener noreferrer"
													>
														{item.title || item.url}
													</a>
												) : (
													<span class="text-zinc-200">{item.title || '—'}</span>
												)}
												{item.ioc_type && (
													<span class="ml-2 rounded-md border border-white/[0.06] bg-white/[0.04] px-1.5 py-0.5 text-[10px] uppercase tracking-wide text-zinc-400">
														{item.ioc_type}
													</span>
												)}
											</li>
										))}
									</ul>
								</div>
							)}
						</article>
					))
				}
			</section>
		</main>
	</body>
</html>
